{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "sequential_thinking": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "exa": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "exa-mcp-server",
        "tools=web_search_exa,get_code_context_exa,crawling_exa"
      ]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secret/github_token}"
      }
    },
    "notion": {
      "type": "local",
      "command": ["bunx", "-y", "@notionhq/notion-mcp-server"],
      "environment": {
        "NOTION_TOKEN": "{file:~/.config/opencode/.secret/notion_token}"
      }
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    }
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:20128/v1",
        "apiKey": "{file:~/.config/opencode/.secret/9router_token}"
      },
      "models": {
        "ag/claude-opus-4-6-thinking": {
          "name": "ag/claude-opus-4-6-thinking",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "ag/claude-sonnet-4-6": {
          "name": "ag/claude-sonnet-4-6",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "ag/gemini-3-flash": {
